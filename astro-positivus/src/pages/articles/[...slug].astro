---
import MainLayout from "../../layouts/MainLayout.astro";
import Tags from "../../components/ui/Tags.astro";
// 1. Added missing getCollection and CollectionEntry imports
import { getCollection } from 'astro:content';
import type { CollectionEntry } from "astro:content";
import { formatDate } from "../../utils";

import "../../styles/global.css";

// 2. Added explicit types so article is not implicitly 'any'
export async function getStaticPaths() {
  const allArticles: CollectionEntry<'blog'>[] = await getCollection('blog');
  
  return allArticles.map((article) => ({
    params: { slug: article.slug },
    props: { article } // Pass the full article object down as a prop
  }));
}

// 3. Define the structural contract for the incoming props
interface Props {
  article: CollectionEntry<'blog'>;
}

// 4. Use Astro.props instead of Astro.params lookup
const { article } = Astro.props;

// 5. Safely render your content without risking empty 'never' types
const { Content } = await article.render();
---

<MainLayout title="Welcome to My site">
	<main class="space-y-40 mb-40 pt-24">
      <section class="bg-white">
          <div class="gap-16 items-center py-8 px-4 mx-auto max-w-screen-xl lg:grid lg:grid-cols-1 lg:py-16 lg:px-3">
              <div class="font-light text-gray-500 sm:text-lg">
                  <a href="/articles" class="inline-flex items-center font-medium text-black hover:text-green my-4">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="h-6 w-6">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18">
                        </path>
                    </svg>
                    <span class="ml-1 font-bold text-lg">All Articles</span>
                  </a>
                  {/* 6. Changed 'entry' references to 'article' */}
                  <h2 class="mb-4 text-4xl tracking-tight font-extrabold text-gray-900">{article.data.title}</h2>
                  <h3 class="text-lg mb-2">Written by {article.data.author} on {formatDate(article.data.pubDate)}</h3>
                  <Tags tags={article.data.tags} />
                  <img src={'/blog/' + article.data.image} alt="Article Image" class="w-full h-auto rounded-xl my-6" />
                  <div class="content">
                    <Content/>
                  </div>
              </div>
          </div>
      </section>
	</main>
</MainLayout>
