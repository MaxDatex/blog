---
import { Image } from "astro:assets";
import Card from "../ui/Card.astro";
import Section from "./Section.astro";

import propImg from "../../assets/pics/cta_proposal.svg";
---

<Section>
  <Card>
    <div
      class="flex bg-[#F3F3F3] rounded-[45px] p-[60px] relative mt-[123px] mb-[80px]"
    >
      <div class="w-full md:w-[40%] flex flex-col gap-[26px]">
        <h2 class="text-3xl font-medium">Let's uncover your hidden email revenue</h2>
        <p>
          Contact us today for a complimentary email infrastructure and flow audit. 
          We'll show you exactly where your brand is leaving money on the table.
        </p>
        <a href="/contactus" target="_blank" class="btn-primary text-center">Book a consultation</a>
      </div>
      <picture
        class="hidden md:flex absolute left-[60%] lg:right-0 top-[-15%] h-[500px] items-center justify-center"
      >
        <Image
          src={propImg}
          alt="This is an illustration"
          class="hidden md:flex lg:h-full lg:w-auto"
        />
      </picture>
    </div>
  </Card>
</Section>
